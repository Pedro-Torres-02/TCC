# Credenciais do Sesmo Web (NÃO comitar o .env real)
SESMO_URL=https://cbmed.sesmoweb.com.br/
SESMO_USUARIO=
SESMO_SENHA=

# Pasta raiz com todas as planilhas do processo
# Os arquivos são encontrados automaticamente por padrão (nome contém o número da fila)
PASTA_EXECUTAR=C:\Users\cbmed\OneDrive\Documentos\BSOCIAL\CBMED\Executar

# Nome da sheet dentro da planilha Importação Matrícula
SHEET_IMPORTACAO_MATRICULA=Importação do Colaborador

# Dash: escolha um dos dois modos
# Modo 1 — chamar uipath_bridge.py existente
DASH_BRIDGE_PATH=C:\Users\cbmed\OneDrive\Documentos\BSOCIAL\DASH\Dash
# Modo 2 — POST direto para endpoint (deixe vazio se usar o modo 1)
DASH_ENDPOINT=

# Selenium (headless=true para rodar sem abrir janela)
HEADLESS=false
